network:
  version: 2
  ethernets:
    enp1s0:
      dhcp4: true
      dhcp4-overrides:
        use-dns: true
      dhcp-identifier: mac
      routes:
{% for peer_name, peer in bare_metal_hosts.items() if peer_name != vm.host %}
        - to: {{ peer.vm_subnet }}
          via: {{ bare_metal_hosts[vm.host].vm_gateway }}
{% endfor %}
