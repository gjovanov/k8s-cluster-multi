prometheus:
  prometheusSpec:
    scrapeInterval: 30s
    evaluationInterval: 30s
    retention: {{ prometheus_retention }}
    resources:
      requests:
        cpu: 500m
        memory: 768Mi
      limits:
        cpu: "2"
        memory: {{ prometheus_memory_limit }}
    storageSpec:
      emptyDir:
        sizeLimit: {{ prometheus_storage_size }}

grafana:
  adminPassword: "{{ grafana_admin_password }}"
  service:
    type: NodePort
    nodePort: 30300
  resources:
    requests:
      cpu: 100m
      memory: 128Mi
    limits:
      cpu: 500m
      memory: 256Mi
  sidecar:
    dashboards:
      enabled: true
      label: grafana_dashboard
      searchNamespace: ALL

alertmanager:
  alertmanagerSpec:
    resources:
      requests:
        cpu: 50m
        memory: 64Mi
      limits:
        cpu: 200m
        memory: 128Mi
  config:
    global:
      smtp_smarthost: "{{ alertmanager_smtp_host }}"
      smtp_from: "{{ alertmanager_smtp_from }}"
      smtp_auth_username: "{{ alertmanager_smtp_user }}"
      smtp_auth_password: "{{ alertmanager_smtp_password }}"
      smtp_require_tls: true
    route:
      group_by: ['alertname', 'namespace']
      group_wait: 30s
      group_interval: 5m
      repeat_interval: 4h
      receiver: 'email'
      routes:
        - match:
            severity: critical
          receiver: 'email'
          repeat_interval: 1h
    receivers:
      - name: 'email'
        email_configs:
          - to: "{{ alertmanager_smtp_to }}"
            send_resolved: true

nodeExporter:
  resources:
    requests:
      cpu: 20m
      memory: 32Mi
    limits:
      cpu: 100m
      memory: 64Mi

kubeProxy:
  enabled: false

kubeEtcd:
  enabled: false

kubeControllerManager:
  enabled: false

kubeScheduler:
  enabled: false

additionalPrometheusRulesMap:
  coturn-rules:
    groups:
      - name: coturn
        rules:
          - alert: COTURNPodDown
            expr: kube_deployment_status_replicas_available{namespace="{{ coturn_namespace }}", deployment=~"coturn-.*"} < 1
            for: 2m
            labels:
              severity: critical
            annotations:
              summary: "COTURN pod {{ '{{' }} $labels.deployment {{ '}}' }} is down"
          - alert: COTURNPodRestarting
            expr: increase(kube_pod_container_status_restarts_total{namespace="{{ coturn_namespace }}"}[1h]) > 3
            for: 5m
            labels:
              severity: warning
            annotations:
              summary: "COTURN pod restarting frequently"
          - alert: COTURNHighMemory
            expr: container_memory_working_set_bytes{namespace="{{ coturn_namespace }}"} / container_spec_memory_limit_bytes{namespace="{{ coturn_namespace }}"} > 0.85
            for: 5m
            labels:
              severity: warning
            annotations:
              summary: "COTURN memory usage above 85%"
      - name: nodes
        rules:
          - alert: NodeHighCPU
            # k8s-worker-2 (zeus) hosts the Ollama systemd service which is
            # capped at 10/12 cores via CPUQuota=1000% but legitimately
            # bursts to 90%+ during inference. Apply 95% threshold there;
            # 85% everywhere else.
            expr: |-
              (100 - (avg by(instance) (rate(node_cpu_seconds_total{mode="idle"}[5m])) * 100) > 85
                and on(instance) (node_uname_info{nodename!="k8s-worker-2"}))
              or
              (100 - (avg by(instance) (rate(node_cpu_seconds_total{mode="idle"}[5m])) * 100) > 95
                and on(instance) (node_uname_info{nodename="k8s-worker-2"}))
            for: 30m
            labels:
              severity: warning
            annotations:
              summary: "Node {{ '{{' }} $labels.instance {{ '}}' }} CPU above threshold for 30m"
          - alert: NodeHighMemory
            expr: (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100 > 90
            for: 5m
            labels:
              severity: warning
            annotations:
              summary: "Node {{ '{{' }} $labels.instance {{ '}}' }} memory above 90%"
          - alert: NodeDiskSpaceLow
            expr: (1 - node_filesystem_avail_bytes{mountpoint="/"} / node_filesystem_size_bytes{mountpoint="/"}) * 100 > 85
            for: 10m
            labels:
              severity: warning
            annotations:
              summary: "Node {{ '{{' }} $labels.instance {{ '}}' }} disk above 85%"
