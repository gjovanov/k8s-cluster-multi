flowchart TD
    P0["Phase 0: Teardown Old<br/>00-teardown-old.yml<br/>Remove previous cluster"]
    P1["Phase 1: Host Bootstrap<br/>01-host-bootstrap.yml<br/>Create user, install packages"]
    P2["Phase 2: Generate SSH Keys<br/>02-generate-ssh-keys.yml<br/>Per-host ed25519 keys"]
    P3["Phase 3: Host Setup<br/>03-host-setup.yml<br/>KVM, libvirt, bridge network"]
    P4["Phase 4: WireGuard Mesh<br/>04-wireguard.yml<br/>wg0 on 3 hosts, routing"]
    P5["Phase 5: VM Provisioning<br/>05-vm-provision.yml<br/>Cloud-init, qcow2, virt-install"]
    P6["Phase 6: HAProxy<br/>06-haproxy.yml<br/>127.0.0.1:8443 on every node"]
    P7["Phase 7: K8s Prerequisites<br/>07-k8s-common.yml<br/>containerd, kubeadm, kubelet"]
    P8["Phase 8: K8s Masters<br/>08-k8s-masters.yml<br/>kubeadm init + join, Cilium"]
    P9["Phase 9: K8s Workers<br/>09-k8s-workers.yml<br/>kubeadm join workers"]
    P10["Phase 10: COTURN Deploy<br/>10-coturn-deploy.yml<br/>3 COTURN pods, TLS certs"]
    P11["Phase 11: Host Networking<br/>11-host-networking.yml<br/>iptables DNAT + SNAT + SNI"]
    P12["Phase 12: Host kubectl<br/>12-host-kubectl.yml<br/>kubectl + HAProxy on hosts"]
    P13["Phase 13: Monitoring<br/>13-monitoring.yml<br/>kube-prometheus-stack"]
    P14["Phase 14: Verify<br/>14-verify.yml<br/>Health checks"]

